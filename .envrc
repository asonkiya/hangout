SESSION="hangout"

# Only create the session if it doesn't already exist
if ! tmux has-session -t "$SESSION" 2>/dev/null; then
  # Window 1: expo dev server
  tmux new-session -d -s "$SESSION" -n "expo" -c "$PWD"
  tmux send-keys -t "$SESSION:expo" "npx expo start" Enter

  # Window 2: nvim
  tmux new-window -t "$SESSION" -n "edit" -c "$PWD"
  tmux send-keys -t "$SESSION:edit" "nvim ." Enter

  # Window 3: claude
  tmux new-window -t "$SESSION" -n "claude" -c "$PWD"
  tmux send-keys -t "$SESSION:claude" "claude --continue" Enter
fi

# Attach or switch to the session
if [[ -z "$TMUX" ]]; then
  tmux attach -t "$SESSION"
else
  tmux switch-client -t "$SESSION"
fi
